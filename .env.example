# PostgreSQL 数据库连接字符串（Vercel Postgres 或 Neon 等）
# 格式: postgresql://用户名:密码@主机:端口/数据库名?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# NextAuth / 会话密钥（生产环境必须修改）
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob 存储令牌（用于图片上传）
# 在 Vercel Dashboard -> Storage -> Blob 中获取
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
